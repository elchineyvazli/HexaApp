<?xml version="1.0" encoding="utf-8"?>

<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FF140C11" />
        </shape>
    </item>

    <item
        android:width="152dp"
        android:height="152dp"
        android:gravity="center">

        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="76dp"
                android:startColor="#55FB9BBD"
                android:centerColor="#22B15090"
                android:endColor="#00B15090" />
        </shape>

    </item>

    <item
        android:width="88dp"
        android:height="88dp"
        android:gravity="center"
        android:drawable="@mipmap/ic_launcher" />

</layer-list>