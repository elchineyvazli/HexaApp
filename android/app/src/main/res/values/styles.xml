<?xml version="1.0" encoding="utf-8"?>

<resources>

    <!--
        Flutter engine ilk karesini çizene kadar gösterilen açık tema.
        Karmaşık animasyon burada değil, Flutter Splash ekranında çalışacaktır.
    -->
    <style
        name="LaunchTheme"
        parent="@android:style/Theme.Light.NoTitleBar">

        <item name="android:windowBackground">
            @drawable/launch_background
        </item>

        <item name="android:windowDrawsSystemBarBackgrounds">
            true
        </item>

        <item name="android:statusBarColor">
            @android:color/transparent
        </item>

        <item name="android:navigationBarColor">
            #FFFFF7FA
        </item>

        <item name="android:windowLightStatusBar">
            true
        </item>

        <item name="android:windowActionModeOverlay">
            true
        </item>
    </style>

    <!--
        Native splash kaldırıldıktan sonra Flutter'ın ilk yüzeyi hazır olana
        kadar görülebilecek kısa geçiş arka planı.
    -->
    <style
        name="NormalTheme"
        parent="@android:style/Theme.Light.NoTitleBar">

        <item name="android:windowBackground">
            #FFFFF7FA
        </item>

        <item name="android:windowDrawsSystemBarBackgrounds">
            true
        </item>

        <item name="android:statusBarColor">
            @android:color/transparent
        </item>

        <item name="android:navigationBarColor">
            #FFFFF7FA
        </item>

        <item name="android:windowLightStatusBar">
            true
        </item>

        <item name="android:windowActionModeOverlay">
            true
        </item>
    </style>

</resources>