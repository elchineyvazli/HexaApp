<?xml version="1.0" encoding="utf-8"?>

<resources>

    <!-- Sistem koyu temadayken kullanılan native başlangıç teması. -->
    <style
        name="LaunchTheme"
        parent="@android:style/Theme.Black.NoTitleBar">

        <item name="android:windowBackground">
            @drawable/launch_background
        </item>

        <item name="android:windowDrawsSystemBarBackgrounds">
            true
        </item>

        <item name="android:statusBarColor">
            @android:color/transparent
        </item>

        <item name="android:navigationBarColor">
            #FF140C11
        </item>

        <item name="android:windowLightStatusBar">
            false
        </item>

        <item name="android:windowActionModeOverlay">
            true
        </item>
    </style>

    <!-- HexaTheme.darkTheme ile eşleşen geçiş yüzeyi. -->
    <style
        name="NormalTheme"
        parent="@android:style/Theme.Black.NoTitleBar">

        <item name="android:windowBackground">
            #FF140C11
        </item>

        <item name="android:windowDrawsSystemBarBackgrounds">
            true
        </item>

        <item name="android:statusBarColor">
            @android:color/transparent
        </item>

        <item name="android:navigationBarColor">
            #FF140C11
        </item>

        <item name="android:windowLightStatusBar">
            false
        </item>

        <item name="android:windowActionModeOverlay">
            true
        </item>
    </style>

</resources>