rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isVideoUpload(userId) {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= 200 * 1024 * 1024
        && request.resource.contentType != null
        && request.resource.contentType.matches('video/.*')
        && request.resource.metadata.ownerId == userId;
    }

    function isImageUpload(maxBytes) {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= maxBytes
        && request.resource.contentType != null
        && request.resource.contentType.matches('image/.*');
    }

    match /videos/{userId}/{fileName} {
      allow read: if signedIn();
      allow create: if isOwner(userId) && isVideoUpload(userId);
      allow delete: if isOwner(userId);
      allow update: if false;
    }

    match /profile_images/{userId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId)
        && isImageUpload(5 * 1024 * 1024);
      allow delete: if isOwner(userId);
    }

    match /avatars/{userId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId)
        && isImageUpload(5 * 1024 * 1024);
      allow delete: if isOwner(userId);
    }

    match /thumbnails/{userId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId)
        && isImageUpload(8 * 1024 * 1024);
      allow delete: if isOwner(userId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
