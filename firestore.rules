rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }
    function userPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }
    function usernamePath(usernameKey) {
      return /databases/$(database)/documents/usernames/$(usernameKey);
    }
    function videoPath(videoId) {
      return /databases/$(database)/documents/videos/$(videoId);
    }
    function signalPath(videoId, userId) {
      return /databases/$(database)/documents/videos/$(videoId)/signals/$(userId);
    }
    function legacyLikePath(videoId, userId) {
      return /databases/$(database)/documents/videos/$(videoId)/likes/$(userId);
    }
    function viewPath(videoId, userId) {
      return /databases/$(database)/documents/videos/$(videoId)/views/$(userId);
    }
    function followingPath(followerId, followingId) {
      return /databases/$(database)/documents/users/$(followerId)/following/$(followingId);
    }
    function followerPath(followingId, followerId) {
      return /databases/$(database)/documents/users/$(followingId)/followers/$(followerId);
    }
    function validUsernameKey(value) {
      return value is string && value.size() >= 3 && value.size() <= 24 && value.matches('^[a-z0-9][a-z0-9._]{1,22}[a-z0-9]$');
    }
    function signalCount(data) {
      return data.get('signalCount', data.get('likesCount', 0));
    }
    function validUserCreate(userId) {
  return request.resource.data.keys().hasOnly([
      'uid',
      'email',
      'emailVerified',
      'isAnonymous',
      'username',
      'usernameKey',
      'displayName',
      'photoUrl',
      'profileImageUrl',
      'bio',
      'followersCount',
      'followingCount',
      'isProfileCompleted',
      'authProvider',
      'authProviders',
      'schemaVersion',
      'createdAt',
      'updatedAt',
      'lastSignInAt'
    ])
    && request.resource.data.uid == userId
    && request.resource.data.get('email', '') is string
    && request.resource.data.emailVerified is bool
    && request.resource.data.isAnonymous is bool
    && request.resource.data.authProvider is string
    && request.resource.data.authProviders is list
    && request.resource.data.get('username', '') == ''
    && request.resource.data.get('usernameKey', '') == ''
    && request.resource.data.get('displayName', '') is string
    && request.resource.data.get('displayName', '').size() <= 40
    && request.resource.data.get('bio', '') is string
    && request.resource.data.get('bio', '').size() <= 160
    && request.resource.data.get('followersCount', 0) == 0
    && request.resource.data.get('followingCount', 0) == 0
    && request.resource.data.get('isProfileCompleted', false) == false
    && request.resource.data.createdAt == request.time
    && request.resource.data.updatedAt == request.time
    && request.resource.data.lastSignInAt == request.time;
}
    function validUserUpdate(userId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let usernameChanged = changed.hasAny(['username', 'usernameKey']);
      let usernameKey = request.resource.data.get('usernameKey', '');
      let validReservation = validUsernameKey(usernameKey) && request.resource.data.get('username', '') == '@' + usernameKey && existsAfter(usernamePath(usernameKey)) && getAfter(usernamePath(usernameKey)).data.uid == userId;
      return changed.hasOnly([
  'uid',
  'email',
  'emailVerified',
  'isAnonymous',
  'username',
  'usernameKey',
  'displayName',
  'bio',
  'category',
  'photoUrl',
  'profileImageUrl',
  'isProfileCompleted',
  'authProvider',
  'authProviders',
  'schemaVersion',
  'updatedAt',
  'lastSignInAt'
])  && request.resource.data.emailVerified is bool
&& request.resource.data.isAnonymous is bool
&& request.resource.data.authProvider is string
&& request.resource.data.authProviders is list&& request.resource.data.get('uid', userId) == userId && resource.data.get('uid', userId) == userId && request.resource.data.get('displayName', '') is string && request.resource.data.get('displayName', '').size() <= 40 && request.resource.data.get('bio', '') is string && request.resource.data.get('bio', '').size() <= 160 && (!usernameChanged || validReservation);
    }
    function validMutation(mutation, actorId, targetId, operation) {
      return mutation is map && mutation.keys().hasOnly(['id', 'actorId', 'targetId', 'operation']) && mutation.get('id', '') is string && mutation.get('id', '').size() >= 8 && mutation.get('id', '').size() <= 256 && mutation.get('actorId', '') == actorId && mutation.get('targetId', '') == targetId && mutation.get('operation', '') == operation && actorId != targetId;
    }
    function matchingFollowMutations(
      actorId,
      targetId,
      operation,
      mutationId
    ) {
      let actorAfter = getAfter(userPath(actorId));
      let targetAfter = getAfter(userPath(targetId));
      let actorMutation = actorAfter.data.get('followMutation', {});
      let targetMutation = targetAfter.data.get('followMutation', {});
      return validMutation(actorMutation, actorId, targetId, operation) && validMutation(targetMutation, actorId, targetId, operation) && actorMutation.get('id', '') == mutationId && targetMutation.get('id', '') == mutationId && actorAfter.data.get('updatedAt', null) == request.time && targetAfter.data.get('updatedAt', null) == request.time;
    }
    function validFollowCounterValues(actorId, targetId, operation) {
      let actorBefore = get(userPath(actorId)).data.get('followingCount', 0);
      let actorAfter = getAfter(userPath(actorId)).data.get('followingCount', 0);
      let targetBefore = get(userPath(targetId)).data.get('followersCount', 0);
      let targetAfter = getAfter(userPath(targetId)).data.get('followersCount', 0);
      return actorBefore is int && actorAfter is int && targetBefore is int && targetAfter is int && actorAfter >= 0 && targetAfter >= 0 && (
          (
            operation == 'follow' && actorAfter == actorBefore + 1 && targetAfter == targetBefore + 1
          ) || (
            operation == 'unfollow' && actorBefore > 0 && targetBefore > 0 && actorAfter == actorBefore - 1 && targetAfter == targetBefore - 1
          )
        );
    }
    function validFollowTransition(
      actorId,
      targetId,
      operation,
      mutationId
    ) {
      let hadFollowing = exists(followingPath(actorId, targetId));
      let hadFollower = exists(followerPath(targetId, actorId));
      let hasFollowing = existsAfter(followingPath(actorId, targetId));
      let hasFollower = existsAfter(followerPath(targetId, actorId));
      let countedFollowing = hadFollowing && get(followingPath(actorId, targetId)).data.get('mutationId', '') != '';
      let countedFollower = hadFollower && get(followerPath(targetId, actorId)).data.get('mutationId', '') != '';
      return (
          operation == 'follow' && !hadFollowing && !hadFollower && hasFollowing && hasFollower && getAfter(followingPath(actorId, targetId)).data.get('mutationId', '') == mutationId && getAfter(followerPath(targetId, actorId)).data.get('mutationId', '') == mutationId
        ) || (
          operation == 'unfollow' && countedFollowing && countedFollower && !hasFollowing && !hasFollower
        );
    }
    function validFollowCounterUpdate(userId) {
      let mutation = request.resource.data.get('followMutation', {});
      let actorId = mutation.get('actorId', userId);
      let targetId = mutation.get('targetId', userId);
      let operation = mutation.get('operation', '');
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let actorDocument = userId == actorId && changed.hasAny(['followingCount']) && changed.hasOnly([
          'followingCount',
          'followMutation',
          'updatedAt'
        ]);
      let targetDocument = userId == targetId && changed.hasAny(['followersCount']) && changed.hasOnly([
          'followersCount',
          'followMutation',
          'updatedAt'
        ]);
      return signedIn() && request.auth.uid == actorId && exists(userPath(actorId)) && exists(userPath(targetId)) && validMutation(mutation, actorId, targetId, operation) && (actorDocument || targetDocument) && validFollowCounterValues(actorId, targetId, operation) && validFollowTransition(
          actorId,
          targetId,
          operation,
          mutation.get('id', '')
        ) && matchingFollowMutations(
          actorId,
          targetId,
          operation,
          mutation.get('id', '')
        );
    }
    function validFollowData(followerId, followingId) {
      return request.resource.data.keys().hasOnly([
          'schemaVersion',
          'followerId',
          'followingId',
          'mutationId',
          'createdAt'
        ]) && request.resource.data.schemaVersion == 2 && request.resource.data.followerId == followerId && request.resource.data.followingId == followingId && request.resource.data.mutationId is string && request.resource.data.mutationId.size() >= 8 && request.resource.data.mutationId.size() <= 256 && request.resource.data.createdAt == request.time && followerId != followingId && exists(userPath(followerId)) && exists(userPath(followingId));
    }
    function validFollowCreateTransition(
      followerId,
      followingId,
      mutationId
    ) {
      return validFollowCounterValues(
          followerId,
          followingId,
          'follow'
        ) && validFollowTransition(
          followerId,
          followingId,
          'follow',
          mutationId
        ) && matchingFollowMutations(
          followerId,
          followingId,
          'follow',
          mutationId
        );
    }
    function validFollowDeleteTransition(followerId, followingId) {
      let mutation = getAfter(userPath(followerId)).data.get('followMutation', {});
      return validMutation(
          mutation,
          followerId,
          followingId,
          'unfollow'
        ) && validFollowCounterValues(
          followerId,
          followingId,
          'unfollow'
        ) && validFollowTransition(
          followerId,
          followingId,
          'unfollow',
          mutation.get('id', '')
        ) && matchingFollowMutations(
          followerId,
          followingId,
          'unfollow',
          mutation.get('id', '')
        );
    }
    function validLegacyFollowDelete(followerId, followingId) {
      return resource.data.get('mutationId', '') == '' && exists(followingPath(followerId, followingId)) && exists(followerPath(followingId, followerId)) && get(followingPath(followerId, followingId)).data.get('mutationId', '') == '' && get(followerPath(followingId, followerId)).data.get('mutationId', '') == '' && !existsAfter(followingPath(followerId, followingId)) && !existsAfter(followerPath(followingId, followerId));
    }
    function validUploaderSnapshot() {
      let profilePath = userPath(request.auth.uid);
      return exists(profilePath)
        && get(profilePath).data.get('isProfileCompleted', false) == true
        && request.resource.data.username
          == get(profilePath).data.get('username', '')
        && request.resource.data.uploaderDisplayName
          == get(profilePath).data.get('displayName', '')
        && (
          request.resource.data.uploaderAvatarUrl
            == get(profilePath).data.get('profileImageUrl', '')
          || request.resource.data.uploaderAvatarUrl
            == get(profilePath).data.get('photoUrl', '')
        );
    }
    function validSourceMetadata(videoId) {
      let format = request.resource.data.get('sourceFormat', '');
      let contentType = request.resource.data.get('sourceContentType', '');
      let videoPathValue = request.resource.data.get('videoStoragePath', '');
      return request.resource.data.get('uploadSchemaVersion', 0) == 2
        && format in ['mp4', 'mov', 'm4v', 'webm']
        && (
          (format == 'mp4' && contentType == 'video/mp4')
          || (format == 'mov' && contentType == 'video/quicktime')
          || (format == 'm4v' && contentType == 'video/x-m4v')
          || (format == 'webm' && contentType == 'video/webm')
        )
        && videoPathValue
          == 'videos/' + request.auth.uid + '/' + videoId + '/source.' + format
        && request.resource.data.get('thumbnailStoragePath', '')
          == 'thumbnails/' + request.auth.uid + '/' + videoId + '/cover.jpg'
        && request.resource.data.get('sourceSizeBytes', 0) is int
        && request.resource.data.get('sourceSizeBytes', 0) > 0
        && request.resource.data.get('sourceSizeBytes', 0)
          <= 200 * 1024 * 1024
        && request.resource.data.get('thumbnailSizeBytes', 0) is int
        && request.resource.data.get('thumbnailSizeBytes', 0) > 0
        && request.resource.data.get('thumbnailSizeBytes', 0)
          <= 8 * 1024 * 1024;
    }
    function validVideoCreate(videoId) {
      return request.resource.data.keys().hasAll([
          'schemaVersion', 'uploadSchemaVersion', 'videoUrl', 'thumbnailUrl',
          'videoStoragePath', 'thumbnailStoragePath', 'sourceFormat',
          'sourceContentType', 'sourceSizeBytes', 'thumbnailSizeBytes',
          'description', 'caption', 'uploaderId', 'username',
          'uploaderDisplayName', 'uploaderAvatarUrl', 'processingStatus',
          'status', 'visibility', 'durationMs', 'width', 'height',
          'aspectRatio', 'signalCount', 'uniqueSignalersCount',
          'signalDistribution', 'likesCount', 'viewsCount', 'sharesCount',
          'commentsCount', 'artifactCount', 'uniqueArtifactSupportersCount',
          'impactScore', 'createdAt', 'updatedAt'
        ]) && request.resource.data.keys().hasOnly([
          'schemaVersion', 'uploadSchemaVersion', 'videoUrl', 'hlsUrl',
          'thumbnailUrl', 'renditionUrls', 'videoStoragePath',
          'thumbnailStoragePath', 'sourceFormat', 'sourceContentType',
          'sourceSizeBytes', 'thumbnailSizeBytes', 'description', 'caption',
          'uploaderId', 'username', 'uploaderDisplayName',
          'uploaderAvatarUrl', 'processingStatus', 'status', 'visibility',
          'durationMs', 'width', 'height', 'aspectRatio', 'signalCount',
          'uniqueSignalersCount', 'signalDistribution', 'likesCount',
          'viewsCount', 'sharesCount', 'commentsCount', 'artifactCount',
          'uniqueArtifactSupportersCount', 'impactScore', 'createdAt',
          'updatedAt'
        ]) && request.resource.data.schemaVersion == 2
        && validSourceMetadata(videoId)
        && request.resource.data.uploaderId == request.auth.uid
        && validUploaderSnapshot()
        && request.resource.data.videoUrl is string
        && request.resource.data.videoUrl.size() > 0
        && request.resource.data.videoUrl.size() <= 4096
        && request.resource.data.thumbnailUrl is string
        && request.resource.data.thumbnailUrl.size() > 0
        && request.resource.data.thumbnailUrl.size() <= 4096
        && request.resource.data.get('hlsUrl', '') == ''
        && request.resource.data.get('renditionUrls', {}) is map
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 2
        && request.resource.data.username.size() <= 80
        && request.resource.data.uploaderDisplayName is string
        && request.resource.data.uploaderDisplayName.size() >= 1
        && request.resource.data.uploaderDisplayName.size() <= 80
        && request.resource.data.uploaderAvatarUrl is string
        && request.resource.data.uploaderAvatarUrl.size() <= 4096
        && request.resource.data.caption is string
        && request.resource.data.caption.size() >= 1
        && request.resource.data.caption.size() <= 300
        && request.resource.data.description == request.resource.data.caption
        && request.resource.data.durationMs is int
        && request.resource.data.durationMs > 0
        && request.resource.data.durationMs <= 180000
        && request.resource.data.width is int
        && request.resource.data.width > 0
        && request.resource.data.width <= 4096
        && request.resource.data.height is int
        && request.resource.data.height > 0
        && request.resource.data.height <= 4096
        && request.resource.data.aspectRatio is number
        && request.resource.data.aspectRatio >= 0.2
        && request.resource.data.aspectRatio <= 5
        && request.resource.data.processingStatus == 'uploaded'
        && request.resource.data.status == 'uploaded'
        && request.resource.data.visibility == 'public'
        && request.resource.data.signalCount == 0
        && request.resource.data.uniqueSignalersCount == 0
        && request.resource.data.signalDistribution is map
        && request.resource.data.likesCount == 0
        && request.resource.data.viewsCount == 0
        && request.resource.data.sharesCount == 0
        && request.resource.data.commentsCount == 0
        && request.resource.data.artifactCount == 0
        && request.resource.data.uniqueArtifactSupportersCount == 0
        && request.resource.data.impactScore == 0
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }
    function validOwnerVideoUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return resource.data.get('uploaderId', '') == request.auth.uid && changed.hasOnly([
          'description', 'caption', 'thumbnailUrl', 'visibility', 'updatedAt'
        ]) && request.resource.data.get('description', '') is string && request.resource.data.get('description', '').size() <= 300 && request.resource.data.get('caption', '') is string && request.resource.data.get('caption', '').size() <= 300 && request.resource.data.get('description', '')
          == request.resource.data.get('caption', '') && request.resource.data.get('thumbnailUrl', '') is string && request.resource.data.get('thumbnailUrl', '').size() <= 4096 && request.resource.data.get('visibility', 'public') in ['public', 'followers_only', 'private'] && request.resource.data.updatedAt == request.time;
    }
    function validSignalAggregateUpdate(videoId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let beforeCount = signalCount(resource.data);
      let afterCount = signalCount(request.resource.data);
      let hadSignal = exists(signalPath(videoId, request.auth.uid)) || exists(legacyLikePath(videoId, request.auth.uid));
      let hasSignal = existsAfter(signalPath(videoId, request.auth.uid)) || existsAfter(legacyLikePath(videoId, request.auth.uid));
      let validTransition =
        (afterCount == beforeCount + 1 && !hadSignal && hasSignal) || (afterCount == beforeCount - 1 && hadSignal && !hasSignal) || (afterCount == beforeCount && hadSignal && hasSignal);
      return changed.hasAny([
          'signalCount', 'likesCount', 'uniqueSignalersCount',
          'signalDistribution'
        ]) && changed.hasOnly([
          'signalCount', 'likesCount', 'uniqueSignalersCount',
          'signalDistribution', 'updatedAt'
        ]) && beforeCount is int && afterCount is int && afterCount >= 0 && validTransition && request.resource.data.get('likesCount', afterCount) == afterCount && request.resource.data.get('uniqueSignalersCount', afterCount)
          == afterCount && request.resource.data.get('signalDistribution', null) is map && request.resource.data.updatedAt == request.time;
    }
    function validCountUpdate(fieldName, delta) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let beforeCount = resource.data.get(fieldName, 0);
      let afterCount = request.resource.data.get(fieldName, 0);
      return changed.hasAny([fieldName]) && changed.hasOnly([fieldName, 'updatedAt']) && beforeCount is int && afterCount is int && afterCount >= 0 && afterCount == beforeCount + delta && (!changed.hasAny(['updatedAt']) || request.resource.data.updatedAt == request.time);
    }
    function validViewAggregateUpdate(videoId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let beforeCount = resource.data.get('viewsCount', 0);
      let afterCount = request.resource.data.get('viewsCount', 0);
      return changed.hasOnly(['viewsCount', 'updatedAt']) && beforeCount is int && afterCount == beforeCount + 1 && !exists(viewPath(videoId, request.auth.uid)) && existsAfter(viewPath(videoId, request.auth.uid)) && request.resource.data.updatedAt == request.time;
    }
    function validModernCommentCreate(videoId, commentId) {
      return request.resource.data.keys().hasOnly([
          'commentId', 'videoId', 'userId', 'username', 'userPhotoUrl',
          'text', 'sticker', 'createdAt', 'updatedAt'
        ]) && request.resource.data.commentId == commentId && request.resource.data.videoId == videoId && request.resource.data.userId == request.auth.uid && request.resource.data.username is string && request.resource.data.username.size() <= 80 && request.resource.data.userPhotoUrl is string && request.resource.data.userPhotoUrl.size() <= 4096 && request.resource.data.text is string && request.resource.data.text.size() >= 1 && request.resource.data.text.size() <= 500 && request.resource.data.sticker is string && request.resource.data.sticker.size() <= 32 && request.resource.data.createdAt == request.time && request.resource.data.updatedAt == request.time;
    }
    function validLegacyCommentCreate() {
      return request.resource.data.keys().hasOnly([
          'username', 'text', 'sticker', 'createdAt'
        ]) && request.resource.data.username is string && request.resource.data.username.size() <= 80 && request.resource.data.text is string && request.resource.data.text.size() >= 1 && request.resource.data.text.size() <= 500 && request.resource.data.sticker is string && request.resource.data.sticker.size() <= 32 && request.resource.data.createdAt == request.time;
    }
    function validNotificationSenderRefresh() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return resource.data.get('senderId', '') == request.auth.uid && request.resource.data.get('senderId', '') == request.auth.uid && request.resource.data.get('targetId', '')
          == resource.data.get('targetId', '') && request.resource.data.get('type', '')
          == resource.data.get('type', '') && request.resource.data.get('senderName', '') is string && request.resource.data.get('senderName', '').size() <= 80 && request.resource.data.get('senderAvatar', '') is string && request.resource.data.get('senderAvatar', '').size() <= 4096 && request.resource.data.get('message', '') is string && request.resource.data.get('message', '').size() <= 240 && request.resource.data.get('isRead', false) == false && request.resource.data.get('createdAt', null) == request.time && changed.hasOnly([
          'senderName', 'senderAvatar', 'message', 'createdAt', 'isRead'
        ]);
    }
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId) && validUserCreate(userId);
      allow update: if signedIn() && (
        (isOwner(userId) && validUserUpdate(userId)) || validFollowCounterUpdate(userId)
      );
      allow delete: if false;
      match /following/{followingId} {
        allow read: if signedIn();
        allow create: if isOwner(userId) && validFollowData(userId, followingId) && validFollowCreateTransition(
            userId, followingId, request.resource.data.mutationId
          );
        allow delete: if isOwner(userId) && (
          validFollowDeleteTransition(userId, followingId) || validLegacyFollowDelete(userId, followingId)
        );
        allow update: if false;
      }
      match /followers/{followerId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.auth.uid == followerId && validFollowData(followerId, userId) && validFollowCreateTransition(
            followerId, userId, request.resource.data.mutationId
          );
        allow delete: if signedIn() && request.auth.uid == followerId && (
          validFollowDeleteTransition(followerId, userId) || validLegacyFollowDelete(followerId, userId)
        );
        allow update: if false;
      }
      match /savedVideos/{videoId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.keys().hasOnly([
            'videoId', 'userId', 'createdAt'
          ]) && request.resource.data.videoId == videoId && request.resource.data.userId == userId && request.resource.data.createdAt == request.time;
        allow delete: if isOwner(userId);
        allow update: if false;
      }
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow create: if signedIn() && request.resource.data.keys().hasOnly([
            'type', 'senderId', 'senderName', 'senderAvatar', 'message',
            'targetId', 'createdAt', 'isRead'
          ]) && request.resource.data.senderId == request.auth.uid && request.resource.data.type in ['signal', 'comment', 'follow', 'artifact'] && request.resource.data.targetId is string && request.resource.data.senderName is string && request.resource.data.senderName.size() <= 80 && request.resource.data.senderAvatar is string && request.resource.data.senderAvatar.size() <= 4096 && request.resource.data.message is string && request.resource.data.message.size() <= 240 && request.resource.data.createdAt == request.time && request.resource.data.isRead == false && (
            (
              request.resource.data.type in ['signal', 'comment', 'artifact'] && exists(videoPath(request.resource.data.targetId)) && get(videoPath(request.resource.data.targetId)).data.get('uploaderId', '') == userId
            ) || (
              request.resource.data.type == 'follow' && request.resource.data.targetId == userId
            )
          );
        allow update: if signedIn() && (
          (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']) && request.resource.data.isRead is bool) || validNotificationSenderRefresh()
        );
        allow delete: if isOwner(userId) || (signedIn() && resource.data.get('senderId', '') == request.auth.uid);
      }
    }
    match /usernames/{usernameKey} {
      allow read: if signedIn();
      allow create: if signedIn() && validUsernameKey(usernameKey) && request.resource.data.keys().hasOnly([
          'uid', 'username', 'createdAt', 'updatedAt'
        ]) && request.resource.data.uid == request.auth.uid && request.resource.data.username == '@' + usernameKey && request.resource.data.createdAt == request.time && request.resource.data.updatedAt == request.time;
      allow update: if signedIn() && validUsernameKey(usernameKey) && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid && request.resource.data.username == '@' + usernameKey && request.resource.data.get('createdAt', null)
          == resource.data.get('createdAt', null) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['username', 'updatedAt']) && request.resource.data.updatedAt == request.time;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }
    match /videos/{videoId} {
      allow read: if signedIn();
      allow create: if signedIn() && validVideoCreate(videoId);
      allow update: if signedIn() && (
        validOwnerVideoUpdate() || validSignalAggregateUpdate(videoId) || validCountUpdate('commentsCount', 1) || validCountUpdate('commentsCount', -1) || validCountUpdate('sharesCount', 1) || validViewAggregateUpdate(videoId)
      );
      allow delete: if signedIn() && resource.data.get('uploaderId', '') == request.auth.uid;
      match /views/{userId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && exists(videoPath(videoId)) && get(videoPath(videoId)).data.get('uploaderId', '') != userId && request.resource.data.keys().hasOnly([
            'videoId', 'userId', 'qualifiedWatchMs', 'durationMs', 'createdAt'
          ]) && request.resource.data.videoId == videoId && request.resource.data.userId == userId && request.resource.data.qualifiedWatchMs is int && request.resource.data.qualifiedWatchMs > 0 && request.resource.data.durationMs is int && request.resource.data.durationMs > 0 && (
            get(videoPath(videoId)).data.get('durationMs', 0) <= 0 || request.resource.data.durationMs
              == get(videoPath(videoId)).data.get('durationMs', 0)
          ) && (
            request.resource.data.qualifiedWatchMs >= 2000 || request.resource.data.qualifiedWatchMs * 5
              >= request.resource.data.durationMs
          ) && request.resource.data.createdAt == request.time;
        allow update, delete: if false;
      }
      match /signals/{userId} {
        allow read: if signedIn();
        allow create: if isOwner(userId) && request.resource.data.keys().hasOnly([
            'videoId', 'userId', 'reason', 'qualifiedWatchMs', 'sessionId',
            'createdAt', 'updatedAt'
          ]) && request.resource.data.videoId == videoId && request.resource.data.userId == userId && request.resource.data.reason in [
            'learned_something', 'inspired', 'thought_provoking', 'helpful',
            'encouraging', 'entertaining', 'artistic', 'other'
          ] && request.resource.data.get('qualifiedWatchMs', 0) >= 0 && request.resource.data.createdAt == request.time && request.resource.data.updatedAt == request.time;
        allow update: if isOwner(userId) && request.resource.data.videoId == resource.data.videoId && request.resource.data.userId == resource.data.userId && request.resource.data.createdAt == resource.data.createdAt && request.resource.data.reason in [
            'learned_something', 'inspired', 'thought_provoking', 'helpful',
            'encouraging', 'entertaining', 'artistic', 'other'
          ] && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'reason', 'qualifiedWatchMs', 'sessionId', 'updatedAt'
            ]) && request.resource.data.updatedAt == request.time;
        allow delete: if isOwner(userId);
      }
      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn() && (
          validModernCommentCreate(videoId, commentId) || validLegacyCommentCreate()
        );
        allow delete: if signedIn() && (
          resource.data.get('userId', '') == request.auth.uid || get(videoPath(videoId)).data.get('uploaderId', '')
            == request.auth.uid
        );
        allow update: if false;
      }
      match /likes/{userId} {
        allow read: if signedIn();
        allow delete: if isOwner(userId);
        allow create, update: if false;
      }
      match /artifacts/{artifactId} {
        allow read: if signedIn();
        allow write: if false;
      }
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
